<TestItem CLASS="ssmc" METHOD="list">
<Stem>
  <Paragraph>
   <Sentence>
     Let <italics>a</italics><sub>1</sub>, <italics>a</italics><sub>2</sub>, <italics>a</italics><sub>3</sub>, 
	<emphasis> ...</emphasis>, <italics>a</italics><sub><italics>n</italics></sub>, <emphasis> ...</emphasis> 
	be a sequence of positive numbers.  
     The first four terms of the sequence are given below.
     </Sentence>
   </Paragraph>
   <Paragraph><Sentence><blockquote> 4.07, 10.07, 16.07, 22.07,<emphasis> ...</emphasis>
     </blockquote></Sentence></Paragraph>
  <Paragraph>
   <Sentence>
     Select the correct rule for finding the (<italics>n</italics>+1)th term from the <italics>n</italics>th term.
     </Sentence>
   </Paragraph>
  </Stem>

<Distractor_list>
  <Distractor><Paragraph><Sentence> <italics>a</italics><sub><italics>n</italics>+1</sub> = <italics>a</italics><sub><italics>n</italics></sub> + 4.07 </Sentence></Paragraph></Distractor>
  <Distractor><Paragraph><Sentence> <italics>a</italics><sub><italics>n</italics>+1</sub> = 6<italics>a</italics><sub><italics>n</italics></sub> </Sentence></Paragraph></Distractor>
  <Distractor><Paragraph><Sentence> <italics>a</italics><sub><italics>n</italics>+1</sub> = <italics>a</italics><sub><italics>n</italics></sub> + 6 </Sentence></Paragraph></Distractor>
  <Distractor><Paragraph><Sentence> <italics>a</italics><sub><italics>n</italics>+1</sub> = 6<italics>a</italics><sub><italics>n</italics></sub> + 4.07 </Sentence></Paragraph></Distractor>
  <Distractor><Paragraph><Sentence> <italics>a</italics><sub><italics>n</italics>+1</sub> = <italics>a</italics><sub><italics>n</italics></sub> - 6  </Sentence></Paragraph></Distractor>
</Distractor_list>

