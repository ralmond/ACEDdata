<TestItem CLASS="FR" METHOD="keyinput">
<Stimulus TYPE="text">
<Paragraph>
  <Sentence>The cost to rent a motorbike is given by the following formula:
  </Sentence>
</Paragraph>
<Paragraph><Sentence>Cost = ($3.50 x number of hours) + $3
  </Sentence>
</Paragraph>
	  <TABLE>
	<TR>
		<TD class="underLine"><Emphasis>Time in Hours</Emphasis></TD>
		<TD class="underLine"><Emphasis>Cost in Dollars</Emphasis></TD>
	</TR>
	<TR>
		<TD>1</TD>
		<TD>6.50</TD>
	</TR>
	<TR>
		<TD>4</TD>
		<TD><Emphasis>A</Emphasis></TD>
	</TR>
	<TR>
		<TD><Emphasis>B</Emphasis></TD>
		<TD>24.00</TD>
	</TR>
  </TABLE>
</Stimulus>
<Stem>
  <Paragraph><Sentence>
  Fill in the values below for <Emphasis>A</Emphasis> and <Emphasis>B</Emphasis> from the table.
    </Sentence></Paragraph>
	
</Stem>

<input_collection>
  <inputfield ID="1" type="limited" size="shortest">Enter the value for <Emphasis>A:</Emphasis> $</inputfield>
  <inputfield ID="2" type="inline" size="shortest">Enter the value for <Emphasis>B:</Emphasis></inputfield>
     <descriptor>hours</descriptor>
</input_collection>

<key TYPE="Compound">
    <response SCORE="1" EVIDENCEVAL="1">
		<observable ID="1" TYPE="math">17</observable>
		<observable ID="2" TYPE="math">6</observable>    
        <feedback TYPE="Student">Correct, good job!</feedback>
        <feedback TYPE="Teacher">The student go this item correct.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
		<observable ID="1" TYPE="math">17</observable>
		<observable ID="2" TYPE="FuzzyString"></observable>    
        <feedback TYPE="Student">Sorry, that's not right.  You needed to fill in both values.</feedback>
        <feedback TYPE="Teacher">Student didn't fill in both cells.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
		<observable ID="1" TYPE="FuzzyString"></observable>
		<observable ID="2" TYPE="math">6</observable>    
        <feedback TYPE="Student">Sorry, that's not right.  You needed to fill in both values.</feedback>
        <feedback TYPE="Teacher">Student didn't fill in both cells.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
        <observable ANY="true"/>
        <feedback TYPE="Student">Sorry, that's incorrect.  Since the formula is given in the problem, apply that instead of looking for a pattern in the numbers. To get value A, multiply the number of hours by the rate of $3.50 per hour, and add $3. Your result will be in dollars. To get the value for B, apply inverse operations in reverse order: First, subtract $3 from $24.00. Then divide this amount by the rate, $3.50 per hour. Your final result will be in hours. </feedback>
        <feedback TYPE="Teacher">Not sure what the problem is.</feedback>
    </response>
</key>	
