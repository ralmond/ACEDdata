<TestItem CLASS="FR" METHOD="keyinput">
<Stem>
	<Paragraph><Sentence>Give the first 3 terms of an arithmetic sequence that satisfies the following:</Sentence> 
        </Paragraph>
        <Blockquote>
	  <Paragraph><Sentence>1. The first term is a positive integer between 6 and 8, inclusive.</Sentence> 
          </Paragraph>
	  <Paragraph><Sentence>2. The common difference is a negative integer between -8 and -6, inclusive.</Sentence> 
          </Paragraph>
        </Blockquote>
        <Paragraph><Sentence>
          <Emphasis>Note:</Emphasis> There is more than one correct answer. Any example 
           you choose that meets the above requirements will be scored as correct.   
        </Sentence></Paragraph>
</Stem>
<input_collection>
	<inputfield  ID="1" type="inline" size="shortest">Enter your answers here:</inputfield>
	<inputfield ID="2" type="inline" size="shortest">,</inputfield>
	<inputfield ID="3" type="inline" size="shortest"> and </inputfield>
</input_collection>
