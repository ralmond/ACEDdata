<TestItem CLASS="FR" METHOD="keyinput">
<Stem>
	<Paragraph><Sentence>Extend the following sequence by giving the next two terms: 
	<Blockquote>1, 1, 2, 3, 5, <Emphasis> ... </Emphasis></Blockquote></Sentence> 
        </Paragraph>
</Stem>
	<input_collection>
	<inputfield  ID="1" type="inline" size="shortest"> Enter your answers here:</inputfield>
	<inputfield  ID="2" type="inline" size="shortest"> and </inputfield>
</input_collection>
<key TYPE="Compound">
    <response SCORE="1" EVIDENCEVAL="1">
		<observable ID="1" TYPE="math">8</observable>
		<observable ID="2" TYPE="math">13</observable>    
        <feedback TYPE="Student">Right!</feedback>
        <feedback TYPE="Teacher">The student got this item correct.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
		<observable ID="1" TYPE="math">8</observable>
		<observable ID="2" TYPE="math">11</observable>    
