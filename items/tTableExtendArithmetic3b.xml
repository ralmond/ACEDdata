<TestItem CLASS="FR" METHOD="keyinput">
<Stimulus TYPE="text">
  <TABLE>
	<TR>
		<TD class="underLine"><Emphasis>Term Number</Emphasis></TD>
		<TD class="underLine"><Emphasis>Term Value</Emphasis></TD>
	</TR>
	<TR>
		<TD>1</TD>
		<TD>8</TD>
	</TR>
	<TR>
		<TD>3</TD>
		<TD><Emphasis>A</Emphasis></TD>
	</TR>
	<TR>
		<TD><Emphasis>B</Emphasis></TD>
		<TD>16</TD>
	</TR>
	<TR>
		<TD>8</TD>
		<TD>22</TD>
	</TR>
  </TABLE>
</Stimulus>

<Stem>
  <Paragraph><Sentence>
  The numbers in the table represent terms in an arithmetic sequence. 
  Complete the table by filling in the cells for A and B. </Sentence></Paragraph>
  <Paragraph><Sentence>
  <Emphasis>Hint:</Emphasis> the term numbers are not listed consecutively.
    </Sentence></Paragraph>
	
</Stem>

<input_collection>
  <inputfield ID="1" type="limited" size="shortest">Enter the value for <Emphasis>A:</Emphasis></inputfield>
  <inputfield ID="2" type="limited" size="shortest">Enter the value for <Emphasis>B:</Emphasis></inputfield>
</input_collection>

<key TYPE="Compound">
    <response SCORE="1" EVIDENCEVAL="1">
        <observable ID="1" TYPE="math">12</observable>
        <observable ID="2" TYPE="math">5</observable>
        <feedback TYPE="Student">Right!</feedback>
        <feedback TYPE="Teacher">The student got this item correct.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
        <observable ANY="true"/>
        <feedback TYPE="Student">Sorry, that was incorrect. A good way to solve problems like this is to
                                 write out all the term numbers, and then try to fill in the corresponding
                                 term values by finding
                                 the common difference.  The common difference here is 2, and the correct value
                                 for A is 12 and for B is 5.</feedback>
        <feedback TYPE="Teacher">The student got this item incorrect.</feedback>
    </response>
</key>	
<Metadata>
    <AeL ItemNode="tTableExtendArithmetic3b" Difficulty="3">
        <PMNode LINK="true">TableArithmetic</PMNode>
        <PMNode>ExtendArithmetic</PMNode>
    </AeL>
</Metadata>
 
</TestItem>
