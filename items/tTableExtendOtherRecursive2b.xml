<TestItem CLASS="FR" METHOD="keyinput">
<Stimulus TYPE="text">
  <TABLE>
	<TR>
		<TD class="underLine"><Emphasis>Term Number</Emphasis></TD>
		<TD class="underLine"><Emphasis>Term Value</Emphasis></TD>
	</TR>
	<TR>
		<TD>1</TD>
		<TD>1</TD>
	</TR>
	<TR>
		<TD>2</TD>
		<TD>3</TD>
	</TR>
	<TR>
		<TD>3</TD>
		<TD>6</TD>
	</TR>
	<TR>
		<TD>4</TD>
		<TD>10</TD>
	</TR>
	<TR>
		<TD>5</TD>
		<TD><Emphasis>A</Emphasis></TD>
	</TR>
	<TR>
		<TD>6</TD>
		<TD>21</TD>
	</TR>
	<TR>
		<TD>7</TD>
		<TD><Emphasis>B</Emphasis></TD>
	</TR>
  </TABLE>
</Stimulus>

<Stem>
  <Paragraph><Sentence>
  The numbers in the table represent terms in a recursive sequence. 
   Fill in the values below.
      </Sentence></Paragraph>
	
</Stem>

<input_collection>
  <inputfield ID="1" type="limited" size="shortest">Enter the value for <Emphasis>A:</Emphasis></inputfield>
  <inputfield ID="2" type="limited" size="shortest">Enter the value for <Emphasis>B:</Emphasis></inputfield>
</input_collection>



<key TYPE="Compound">
    <response SCORE="1" EVIDENCEVAL="1">
		<observable ID="1" TYPE="math">15</observable>
		<observable ID="2" TYPE="math">28</observable>    
        <feedback TYPE="Student">Right!</feedback>
        <feedback TYPE="Teacher">The student got this item correct.</feedback>
    </response>
    <response SCORE="0" EVIDENCEVAL="0">
	<observable ANY="true"/>        
	<feedback TYPE="Student">Sorry, that was incorrect. The difference in term 
         values (1, 3, 6, 10) increases by 1, across the series.  
         The correct series is: 1, 3, 6, 10, 15, 21, 28. 
         </feedback>
        <feedback TYPE="Teacher">The student got this item incorrect.</feedback>
    </response>
</key>	
